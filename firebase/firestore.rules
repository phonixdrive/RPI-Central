rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isSelf(userID) {
      return signedIn() && request.auth.uid == userID;
    }

    function friendshipDocID(a, b) {
      return a < b ? a + "_" + b : b + "_" + a;
    }

    function areFriends(a, b) {
      return exists(
        /databases/$(database)/documents/friendships/$(friendshipDocID(a, b))
      );
    }

    match /users/{userID} {
      allow read: if signedIn();
      allow create: if isSelf(userID);
      allow update: if isSelf(userID);
      allow delete: if false;

      match /calendarShares/{shareID} {
        allow read: if isSelf(userID);
        allow create: if signedIn() &&
          request.resource.data.ownerID == request.auth.uid &&
          areFriends(request.auth.uid, userID);
        allow update: if isSelf(userID) || (
          signedIn() &&
          resource.data.ownerID == request.auth.uid &&
          areFriends(request.auth.uid, userID)
        );
        allow delete: if isSelf(userID) || (
          signedIn() &&
          resource.data.ownerID == request.auth.uid
        );
      }

      match /socialNotifications/{notificationID} {
        allow read: if isSelf(userID);
        allow create: if signedIn() &&
          request.resource.data.senderID == request.auth.uid &&
          areFriends(request.auth.uid, userID);
        allow update: if isSelf(userID) || (
          signedIn() &&
          resource.data.senderID == request.auth.uid &&
          areFriends(request.auth.uid, userID)
        );
        allow delete: if isSelf(userID) || (
          signedIn() &&
          resource.data.senderID == request.auth.uid
        );
      }
    }

    match /friendRequests/{requestID} {
      allow read: if signedIn() &&
        (resource.data.fromUserID == request.auth.uid || resource.data.toUserID == request.auth.uid);

      allow create: if signedIn() &&
        request.resource.data.fromUserID == request.auth.uid;

      allow update: if signedIn() &&
        resource.data.toUserID == request.auth.uid;

      allow delete: if false;
    }

    match /friendships/{friendshipID} {
      allow read: if signedIn() && request.auth.uid in resource.data.members;
      allow create: if signedIn() && request.auth.uid in request.resource.data.members;
      allow delete: if signedIn() && request.auth.uid in resource.data.members;
      allow update: if false;
    }

    match /friendGroups/{groupID} {
      allow read: if signedIn() && resource.data.ownerID == request.auth.uid;
      allow create: if signedIn() && request.resource.data.ownerID == request.auth.uid;
      allow update: if signedIn() &&
        resource.data.ownerID == request.auth.uid &&
        request.resource.data.ownerID == request.auth.uid;
      allow delete: if signedIn() && resource.data.ownerID == request.auth.uid;
    }

    match /sharedSchedules/{ownerID} {
      allow read: if isSelf(ownerID) || (
        signedIn() &&
        areFriends(request.auth.uid, ownerID) &&
        get(/databases/$(database)/documents/users/$(ownerID)).data.shareSchedule == true
      );
      allow create: if isSelf(ownerID);
      allow update: if isSelf(ownerID);
      allow delete: if isSelf(ownerID);

      match /friendViews/{viewerID} {
        allow read: if isSelf(ownerID) || (
          signedIn() &&
          request.auth.uid == viewerID &&
          areFriends(request.auth.uid, ownerID) &&
          get(/databases/$(database)/documents/users/$(ownerID)).data.shareSchedule == true
        );

        allow create: if isSelf(ownerID);
        allow update: if isSelf(ownerID);
        allow delete: if isSelf(ownerID);
      }
    }
  }
}
